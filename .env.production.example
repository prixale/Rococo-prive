# ============================================
# EJEMPLO CONFIGURACIÓN PRODUCCIÓN
# Copia este contenido a .env y completa los valores
# ============================================

# ---------- GOOGLE OAUTH ----------
# Ve a: https://console.cloud.google.com/apis/credentials
# Crea un OAuth Client ID y configura los URI autorizados
VITE_GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ---------- GOOGLE MAPS ----------
# Ve a: https://console.cloud.google.com/google/maps-apis
# Habilita Maps JavaScript API y Obtén tu API Key
VITE_GOOGLE_MAPS_API_KEY=TU_GOOGLE_MAPS_API_KEY

# ---------- STRIPE (MODO PRODUCCIÓN) ----------
# Ve a: https://dashboard.stripe.com/apikeys
# Usa las claves de "Live Mode" (comienzan con pk_live_ y sk_live_)

# Clave pública (frontend) - Comienza con pk_live_
VITE_STRIPE_PUBLIC_KEY=pk_live_TU_CLAVE_PUBLICA

# Clave secreta (backend) - NUNCA compartir - Comienza con sk_live_
STRIPE_SECRET_KEY=sk_live_TU_CLAVE_SECRETA

# Webhook secret - Ve a: https://dashboard.stripe.com/webhooks
# Configura el endpoint: https://tudominio.com/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_TU_WEBHOOK_SECRET

# ---------- CONFIGURACIÓN ----------
# URL de tu API en producción
VITE_API_URL=https://tu-dominio.com

# Modo producción
MODE=production
